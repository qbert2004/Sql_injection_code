# ============================================================
# SQL Injection Protector AI Agent — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# All values shown are defaults — uncomment and change as needed.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console           # console | json (use json in production)

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# Authentication (REQUIRED in production)
# API_KEY=your-secret-api-key-here

# CORS (comma-separated origins; restrict in production)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Rate Limiting ---
RATE_LIMIT=100               # requests per minute per IP (0 = disabled)

# --- ML Ensemble Thresholds ---
# Fine-tune detection sensitivity. Defaults work well for most cases.
# ENSEMBLE_W_RF=0.25         # Random Forest weight
# ENSEMBLE_W_CNN=0.35        # CNN weight (only RF+CNN active, weights renormalized)
# ENSEMBLE_TAU_HIGH=0.60     # High-confidence injection threshold
# ENSEMBLE_TAU_SEMANTIC=2.0  # Minimum semantic score for INJECTION

# --- Input Limits ---
MAX_INPUT_LENGTH=10000       # Max characters per input field

# --- Incident Logging ---
INCIDENTS_DB=incidents.db    # SQLite database path
CLEANUP_DAYS=90              # Auto-delete incidents older than N days (0 = disabled)
LOG_ALL_REQUESTS=false       # Log SAFE requests too (verbose, for debugging)
